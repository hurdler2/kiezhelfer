# Bu dosyayı kopyalayın: cp .env.example .env.local
# Sonra kendi değerlerinizle doldurun.

# ── Veritabanı ─────────────────────────────────────────────────────────────
# Docker ile çalışırken (docker-compose.yml → kiezhelfer-db, port 5433)
DATABASE_URL="postgresql://kiezhelfer:kiezhelfer123@localhost:5433/kiezhelfer?schema=public"

# ── NextAuth / Auth.js ──────────────────────────────────────────────────────
# Rastgele güçlü bir string: openssl rand -base64 32
AUTH_SECRET="BURAYA_GUCLU_BIR_SECRET_YAZIN"

# ── Google Maps (opsiyonel) ─────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="GOOGLE_MAPS_API_KEY"

# ── Uygulama URL'leri ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3000"
